FROM node:24-alpine AS build

WORKDIR /app/ui

COPY ui/package.json ui/package-lock.json ./
RUN npm ci

COPY ui/ ./

ARG VITE_API_URL=/api
ARG VITE_KEYCLOAK_AUTHORITY=/realms/tertius
ARG VITE_KEYCLOAK_CLIENT_ID=tertius-ui
ENV VITE_API_URL=${VITE_API_URL} \
    VITE_KEYCLOAK_AUTHORITY=${VITE_KEYCLOAK_AUTHORITY} \
    VITE_KEYCLOAK_CLIENT_ID=${VITE_KEYCLOAK_CLIENT_ID}

RUN npm exec vite -- build

FROM nginx:1.29-alpine

ENV API_SERVICE_HOST=tertius-api \
    API_SERVICE_PORT=8000

COPY infra/deploy/nginx/default.conf.template /etc/nginx/templates/default.conf.template
COPY --from=build /app/ui/dist/ /usr/share/nginx/html/

EXPOSE 80
