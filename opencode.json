{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "serena": {
      "type": "local",
      "enabled": true,
      "command": [
        "/root/.local/bin/uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--project",
        "/root/code/Tertius-Web",
        "--transport",
        "stdio"
      ]
    },
    "superpowers": {
      "type": "local",
      "enabled": true,
      "command": [
        "superpowers-mcp"
      ]
    }
  }
}
